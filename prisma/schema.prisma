generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model Booking {
  id          String   @id @default(cuid())
  guestName   String
  guestEmail  String
  guestPhone  String
  eventType   String
  startDate   DateTime
  endDate     DateTime
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
